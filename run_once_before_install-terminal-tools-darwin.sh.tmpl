#!/usr/bin/env bash
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "This setup script is only intended for macOS."
  exit 0
fi

log() {
  printf '\n==> %s\n' "$1"
}

warn() {
  printf '\nWarning: %s\n' "$1" >&2
}

ensure_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    return
  fi

  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
    return
  fi

  if [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
    return
  fi

  warn "Homebrew is not installed. Install it first, then run 'chezmoi apply' again."
  warn "https://brew.sh"
  exit 1
}

ensure_oh_my_zsh() {
  if [[ -d "$HOME/.oh-my-zsh" ]]; then
    return
  fi

  log "Installing Oh My Zsh"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
}

ensure_powerlevel10k() {
  local theme_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k"

  if [[ -d "$theme_dir/.git" ]]; then
    log "Updating Powerlevel10k"
    git -C "$theme_dir" pull --ff-only
    return
  fi

  if [[ -d "$theme_dir" ]]; then
    warn "Powerlevel10k directory already exists but is not a Git checkout: $theme_dir"
    warn "Leaving it unchanged. Remove it manually if you want this script to reinstall it."
    return
  fi

  log "Installing Powerlevel10k"
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$theme_dir"
}

install_brew_bundle() {
  local brewfile="{{ .chezmoi.sourceDir }}/Brewfile"

  if [[ ! -f "$brewfile" ]]; then
    warn "Brewfile not found at $brewfile"
    return
  fi

  log "Installing Homebrew dependencies from Brewfile"
  brew bundle --file "$brewfile"
}

ensure_mason_npm_packages() {
  if ! command -v npm >/dev/null 2>&1; then
    warn "npm is still unavailable after Homebrew setup. Mason may fail to install npm-based language servers."
    return
  fi

  log "Ensuring npm global package directory exists"
  mkdir -p "$HOME/.npm-global"
  npm config set prefix "$HOME/.npm-global"
}

main() {
  ensure_homebrew
  install_brew_bundle
  ensure_oh_my_zsh
  ensure_powerlevel10k
  ensure_mason_npm_packages

  log "Terminal tooling setup complete"
}

main "$@"
