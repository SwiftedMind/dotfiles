{
  "title": "Dictation key to Hyper+F15",
  "rules": [
    {
      "description": "Dictation key → Command+Option+Control+Shift+F15",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "dictation",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "f15",
              "modifiers": [
                "left_command",
                "left_option",
                "left_control",
                "left_shift"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Internal MacBook Fn+F5 → Command+Option+Control+Shift+F15",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "simultaneous": [
              {
                "apple_vendor_top_case_key_code": "keyboard_fn"
              },
              {
                "key_code": "f5"
              }
            ],
            "simultaneous_options": {
              "key_down_order": "strict",
              "key_up_order": "strict_inverse",
              "key_up_when": "any"
            },
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "f15",
              "modifiers": [
                "left_command",
                "left_option",
                "left_control",
                "left_shift"
              ]
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "is_built_in_keyboard": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Emergency fallback: block internal Fn/top-case key",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "apple_vendor_top_case_key_code": "keyboard_fn",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "is_built_in_keyboard": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
