{
  "title": "Dictation key to F15",
  "rules": [
    {
      "description": "External Dictation key → F15",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "dictation",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "f15"
            }
          ]
        }
      ]
    },
    {
      "description": "Internal MacBook F5/Dictation key → F15",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "f5",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "f15"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "is_built_in_keyboard": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Block leaked internal Fn/top-case event",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "apple_vendor_top_case_key_code": "keyboard_fn",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "is_built_in_keyboard": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
