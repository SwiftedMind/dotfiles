prefix_rule(pattern=["cd", "$PWD", "&&", "xcodebuild"], decision="allow")
prefix_rule(pattern=["xcodebuild"], decision="allow")
prefix_rule(pattern=["rm", "-rf", "SymbolInspector/SymbolInspector.tessera"], decision="allow")
prefix_rule(pattern=["swift"], decision="allow")
prefix_rule(pattern=["monocle"], decision="allow")
prefix_rule(pattern=["swiftformat"], decision="allow")
prefix_rule(pattern=["git"], decision="allow")
prefix_rule(pattern=["gh", "issue"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["npx", "-y", "@steipete/oracle"], decision="allow")
prefix_rule(pattern=["git", ["reset", "--hard"]], decision="prompt", match=[["git", "reset", "--hard"]])
prefix_rule(pattern=["rm"], decision="prompt", match=[["rm", "-rf"]])
prefix_rule(pattern=["git", "checkout"], decision="prompt")
prefix_rule(pattern = ["playwright"], decision = "allow")
prefix_rule(pattern=["playwright-cli"], decision="allow")
prefix_rule(pattern=["npm", "run", "dev", "--", "--host", "127.0.0.1", "--port", "4321"], decision="allow")
prefix_rule(pattern=["bun", "run", "dev"], decision="allow")
prefix_rule(pattern=["bun", "run", "astro", "dev"], decision="allow")
prefix_rule(pattern=["bun", "add"], decision="allow")
prefix_rule(pattern=["flowdeck", "build"], decision="allow")
prefix_rule(pattern=["flowdeck", "project", "packages"], decision="allow")
prefix_rule(pattern=["flowdeck"], decision = "allow")
prefix_rule(pattern=["cp", "find"], decision="allow")
prefix_rule(pattern=["swift", "test"], decision="allow")
